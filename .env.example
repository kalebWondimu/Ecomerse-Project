# Backend Environment Variables

# Email Configuration (Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com

# Resend Email Service
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=notifications@your-verified-domain.com

# Contact and Support
CONTACT_EMAIL=support@estore.com

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Backend URL
BACKEND_URL=http://localhost:5000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ecommerce_db

# Payment Gateway Credentials (Add when you have real accounts)
# Telebirr
TELEBIRR_API_KEY=your-telebirr-api-key
TELEBIRR_API_SECRET=your-telebirr-api-secret
TELEBIRR_MERCHANT_ID=your-telebirr-merchant-id

# Chapa
CHAPA_API_KEY=your-chapa-api-key

# CBE Bank
CBE_API_KEY=your-cbe-api-key
CBE_MERCHANT_CODE=your-cbe-merchant-code

# Port
PORT=5000
